{
  "name": "mnemosyne-sync",
  "version": "0.1.0",
  "description": "Sync Mnemosyne memories as markdown notes in your vault. Browse, search, and manage AI agent memory from Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["mnemosyne", "memory", "ai", "agent", "sync"],
  "author": "Abdias J",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.19.0",
    "obsidian": "^1.5.0",
    "tslib": "2.6.0",
    "typescript": "^5.3.0"
  }
}
